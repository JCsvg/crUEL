import java.util.Scanner;

public class Ex8 {

	public static void main(String[] args) {
		Scanner sc = new Scanner(System.in);
		int n, sum = 0;
		System.out.println("Informe a posicao da sequencia de fibonacci: ");
		n = sc.nextInt();
		for (int i = 0; i <= n; i++) {
			if(i < 2) {
				System.out.println(i);
			}else {
			sum = (sum - 1) + (sum - 2);
			System.out.println(sum);
			}
		}
		sc.close();

	}

}

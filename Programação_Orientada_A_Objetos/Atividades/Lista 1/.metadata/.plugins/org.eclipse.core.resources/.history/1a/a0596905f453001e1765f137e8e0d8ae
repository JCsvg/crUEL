import java.util.Scanner;
public class Ex7 {

	public static void main(String[] args) {
		Scanner sc = new Scanner(System.in);
		int n, m;
		System.out.println("informe a quantidade de triangulos: ");
		n = sc.nextInt();
		System.out.println("informe a quantidade de niveis: ");
		m = sc.nextInt();
		for (int i = 0; i <= n; i++) {
			for (int j = 0; j <= m; j++) {
				for (int k = 0; k <= j; k++) {
					System.out.print("*");
				}
				System.out.print("\n");
			}
			System.out.print("\n");
		}
		sc.close();

	}

}
